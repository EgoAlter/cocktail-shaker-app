# Copy this file to .env and fill in your Supabase connection string.
# .env is gitignored — never commit credentials.
#
# Get this from: Supabase project → Settings → Database → Connection string → URI
# Use the "Session mode" pooler URL (port 5432) for local dev, not the transaction pooler.

DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
