# Copy this file to .env and fill in your Supabase connection string.
# .env is gitignored — never commit credentials.
#
# Get this from: Supabase dashboard → project → Connect button (top of page)
# → Session mode, port 5432
#
# NOTE: Supabase uses aws-1-* (not aws-0-*) for some regions.
# Copy the exact string from the dashboard — do not guess the hostname.

DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres
